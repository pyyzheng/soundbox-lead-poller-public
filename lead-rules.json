  "spam_rules": {
    "min_bot_signals": 2,
    "signals": {
      "random_name": "Name > 8 chars with no vowels, OR > 10 chars with high unique-char ratio (>70%) + alternating case",
      "random_email": "Email local part has >= 4 dot-separated segments",
      "random_message": "Message > 10 chars with no vowels, OR > 10 chars with high unique-char ratio (>70%) + alternating case",
      "name+msg_random": "Both name and message trigger any random signal"
    }
  },
  "short_message": {
    "_comment": "留言过短或纯数字硬拦截；allowlist 为允许的短询盘词",
    "enabled": true,
    "min_significant_chars": 5,
    "allowlist": ["quote", "pricing", "inquiry", "quotation", "price", "catalog", "brochure", "moq", "rfq"]
  },
  "test_message": {
    "_comment": "留言仅由测试/占位词组成时硬拦截（如 test test、hello hi）",
    "enabled": true,
    "tokens": [
      "test", "testing", "hello", "hi", "hey", "abc", "asdf", "xxx", "sample",
      "demo", "foo", "bar", "baz", "dummy", "placeholder", "try", "check"
    ]
  },
