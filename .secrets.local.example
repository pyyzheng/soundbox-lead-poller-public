# 本地密钥文件（复制为 .secrets.local 后填入真实值）
# 此文件可 git 提交；.secrets.local 已在 .gitignore 中，切勿提交
#
# 用法：
#   cp .secrets.local.example .secrets.local
#   # 编辑 .secrets.local 填入真实值
#   ./scripts/setup-secrets.sh --local-env    # 生成本地 .env
#   ./scripts/setup-secrets.sh --github       # 上传到 GitHub Actions Secrets

# ── 飞书 ──────────────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=tbluuuXn9WexH8LV
FEISHU_ALERT_WEBHOOK=
FEISHU_REPORT_WEBHOOK=
FEISHU_FILTER_LOG_TABLE_ID=tblNIJHoBg8YAs01
FEISHU_FOLLOWUP_TABLE=tbl3n8TTJYXHG12q
FEISHU_SALES_NOTIFY_TABLE=tblXq1rE7OQCrSgJ

# ── Gmail OAuth ───────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── 智谱 LLM（两个名字 workflow 都有用到，填同一个 key）──
ZHIPU_API_KEY=
GLM_API_KEY=

# ── GitHub（health-check / agent-scan 用，需 repo 权限的 PAT）──
GHA_PAT=

# ── GitHub dispatch（外部触发 Public 仓 Actions，勿与 GHA_PAT 混用）──
# Apps Script 脚本属性 GITHUB_TOKEN ← GITHUB_TOKEN_APPS_SCRIPT
# Cloudflare Worker Secret GITHUB_TOKEN ← GITHUB_TOKEN_CLOUDFLARE
GITHUB_TOKEN_APPS_SCRIPT=
GITHUB_TOKEN_CLOUDFLARE=

# ── Meta Facebook（可选）──────────────────────────
META_PAGE_ACCESS_TOKEN=

# ── Cloudflare（部署 facebook-lead-webhook Worker）──
CLOUDFLARE_API_TOKEN=

# ── 自动回复灰度（可选，有默认值）────────────────
AUTO_REPLY_WORKER_ENABLED=false
AUTO_REPLY_WORKER_DRY_RUN=true
AUTO_REPLY_ALLOWED_SALESPERSONS=Stephanie

# ── 回复转发（可选）──────────────────────────────
SALES_EMAIL_MAP=

# ── cron-job.org 备用触发（可选）─────────────────
CRONJOB_API_KEY=
CRONJOB_JOB_ID=

# ── SMTP 本地发信测试（可选，仅本地调试自动回复时用）──
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
